# =============================================================================
# Local secrets (gitignored). After cloning the repo, run:
#   ./scripts/init-local-env.sh
# then edit the values below. Do not commit `.env`.
#
# For AI-assisted schema generation, install SDKs:
#   pip install -r requirements-ai.txt
# =============================================================================

# Default provider is Gemini (free tier friendly). Optional OpenAI for users who prefer it.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (CLI --model wins when passed)
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o-mini
